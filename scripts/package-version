#!/usr/bin/env python3
import argparse
import re
from pathlib import Path


VERSION_RE = re.compile(
    r"^v?(?P<version>[0-9]+(?:\.[0-9]+){1,2}(?:\.post[0-9]+)?)$"
)


def normalize_version(value):
    value = value.strip()
    match = VERSION_RE.fullmatch(value)
    if match is None:
        raise SystemExit(f"unsupported package version: {value!r}")
    return match.group("version")


def main():
    parser = argparse.ArgumentParser(
        description="Read the retracesoftware-cpython package version from VERSION."
    )
    parser.add_argument(
        "--file",
        type=Path,
        default=Path("VERSION"),
        help="Version file to read.",
    )
    args = parser.parse_args()

    if not args.file.is_file():
        raise SystemExit(f"version file does not exist: {args.file}")
    print(normalize_version(args.file.read_text(encoding="utf-8")))


if __name__ == "__main__":
    main()
