#!/usr/bin/env python3
import argparse
import platform
import shutil
import tarfile
import zipfile
from pathlib import Path

from retrace_packaging import copy_runtime_files


def make_archive(stage, archive):
    if archive.suffix == ".zip":
        with zipfile.ZipFile(archive, "w", zipfile.ZIP_DEFLATED) as zf:
            for path in sorted(stage.rglob("*")):
                if path.is_file():
                    zf.write(path, path.relative_to(stage))
    else:
        with tarfile.open(archive, "w:gz") as tf:
            tf.add(stage, arcname=stage.name)


def main():
    parser = argparse.ArgumentParser(
        description="Package the patched executable and required CPython runtime libraries."
    )
    parser.add_argument("version")
    parser.add_argument("target")
    parser.add_argument("runtime_root", type=Path)
    parser.add_argument(
        "--dist-dir",
        type=Path,
        default=Path("build/dist"),
        help="Directory for the output archive.",
    )
    args = parser.parse_args()

    runtime_root = args.runtime_root.resolve()
    if not runtime_root.is_dir():
        raise SystemExit(f"runtime root does not exist: {runtime_root}")

    dist_dir = args.dist_dir.resolve()
    package_root = Path("build/package") / f"retrace-cpython-{args.version}-{args.target}"
    if package_root.exists():
        shutil.rmtree(package_root)
    package_root.mkdir(parents=True)

    copied = [rel.as_posix() for rel in copy_runtime_files(runtime_root, package_root)]

    dist_dir.mkdir(parents=True, exist_ok=True)
    suffix = ".zip" if platform.system() == "Windows" else ".tar.gz"
    archive = dist_dir / f"{package_root.name}{suffix}"
    if archive.exists():
        archive.unlink()
    make_archive(package_root, archive)

    print(f"Packaged {archive}")
    for rel in copied:
        print(f"  {rel}")


if __name__ == "__main__":
    main()
