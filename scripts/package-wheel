#!/usr/bin/env python3
import argparse
import base64
import csv
import hashlib
import os
import shutil
import stat
import sys
import zipfile
from pathlib import Path


PROJECT_NAME = "retracesoftware-cpython"
WHEEL_DIST_NAME = "retracesoftware_cpython"
PACKAGE_NAME = "retracesoftware_cpython"

PLATFORM_TAGS = {
    "linux-x64": "manylinux_2_39_x86_64",
    "linux-arm64": "manylinux_2_39_aarch64",
    "macos-intel": "macosx_15_0_x86_64",
    "macos-arm64": "macosx_15_0_arm64",
    "windows-x64": "win_amd64",
    "windows-x86": "win32",
    "windows-arm64": "win_arm64",
}

LAUNCHER = r'''"""Launcher for the packaged Retrace CPython executable."""

from __future__ import annotations

import os
import sys
from pathlib import Path


def _runtime_root() -> Path:
    return Path(__file__).resolve().parent / "_runtime"


def _find_executable() -> Path:
    names = ("python.exe", "python")
    root = _runtime_root()
    for name in names:
        for path in root.rglob(name):
            if path.is_file():
                return path
    raise RuntimeError(f"no packaged CPython executable found under {root}")


def main() -> None:
    executable = _find_executable()
    env = os.environ.copy()
    env.setdefault("PYTHONHOME", sys.base_prefix)
    argv = [str(executable), *sys.argv[1:]]
    os.execvpe(str(executable), argv, env)


if __name__ == "__main__":
    main()
'''


def parse_version(version):
    parts = version.split(".")
    if len(parts) < 2 or not all(part.isdigit() for part in parts[:2]):
        raise SystemExit(f"CPython version must start with major.minor: {version}")
    return int(parts[0]), int(parts[1])


def python_tag(version):
    major, minor = parse_version(version)
    return f"cp{major}{minor}"


def wheel_tag(version, target):
    try:
        platform_tag = PLATFORM_TAGS[target]
    except KeyError:
        supported = ", ".join(sorted(PLATFORM_TAGS))
        raise SystemExit(f"unsupported target {target!r}; expected one of: {supported}")
    return f"{python_tag(version)}-none-{platform_tag}"


def dist_info_name(version):
    return f"{WHEEL_DIST_NAME}-{version}.dist-info"


def hash_file(path):
    digest = hashlib.sha256(path.read_bytes()).digest()
    encoded = base64.urlsafe_b64encode(digest).rstrip(b"=").decode("ascii")
    return f"sha256={encoded}", str(path.stat().st_size)


def write_text(path, content, mode=0o644):
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding="utf-8")
    path.chmod(mode)


def copy_runtime(runtime_root, package_root):
    copied = []
    runtime_dest = package_root / "_runtime"
    for src in sorted(runtime_root.rglob("*")):
        if not src.is_file():
            continue
        rel = src.relative_to(runtime_root)
        dest = runtime_dest / rel
        dest.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(src, dest)
        copied.append(dest)

    executables = [path for path in copied if path.name in {"python", "python.exe"}]
    if not executables:
        raise SystemExit(f"no Python executable found under {runtime_root}")
    return copied


def build_stage(version, target, runtime_root, stage):
    if stage.exists():
        shutil.rmtree(stage)
    stage.mkdir(parents=True)

    tag = wheel_tag(version, target)
    package_root = stage / PACKAGE_NAME
    package_root.mkdir()
    write_text(package_root / "__init__.py", f'__version__ = "{version}"\n')
    write_text(package_root / "launcher.py", LAUNCHER)
    copy_runtime(runtime_root, package_root)

    dist_info = stage / dist_info_name(version)
    metadata = f"""Metadata-Version: 2.1
Name: {PROJECT_NAME}
Version: {version}
Summary: Patched CPython runtime artifacts for Retrace
Requires-Python: =={version}
License: Apache-2.0
Project-URL: Source, https://github.com/retracesoftware/retrace-cpython

Retrace-compatible CPython executable built from upstream CPython {version}.
"""
    wheel = f"""Wheel-Version: 1.0
Generator: retrace-cpython package-wheel
Root-Is-Purelib: false
Tag: {tag}
"""
    entry_points = """[console_scripts]
retrace-python = retracesoftware_cpython.launcher:main
"""
    write_text(dist_info / "METADATA", metadata)
    write_text(dist_info / "WHEEL", wheel)
    write_text(dist_info / "entry_points.txt", entry_points)
    write_text(dist_info / "RECORD", "")
    return tag


def wheel_info_for_file(path, arcname):
    info = zipfile.ZipInfo.from_file(path, arcname)
    if path.name == "python" or os.access(path, os.X_OK):
        mode = path.stat().st_mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH
        info.external_attr = (mode & 0xFFFF) << 16
    return info


def write_record(stage, record_path):
    rows = []
    for path in sorted(stage.rglob("*")):
        if not path.is_file():
            continue
        rel = path.relative_to(stage).as_posix()
        if path == record_path:
            rows.append([rel, "", ""])
        else:
            digest, size = hash_file(path)
            rows.append([rel, digest, size])

    with record_path.open("w", newline="", encoding="utf-8") as f:
        writer = csv.writer(f)
        writer.writerows(rows)


def build_wheel(version, target, runtime_root, wheel_dir):
    runtime_root = runtime_root.resolve()
    if not runtime_root.is_dir():
        raise SystemExit(f"runtime root does not exist: {runtime_root}")

    wheel_dir.mkdir(parents=True, exist_ok=True)
    stage = Path("build/wheel-stage") / f"{WHEEL_DIST_NAME}-{version}-{target}"
    tag = build_stage(version, target, runtime_root, stage)
    record_path = stage / dist_info_name(version) / "RECORD"
    write_record(stage, record_path)

    wheel_name = f"{WHEEL_DIST_NAME}-{version}-{tag}.whl"
    wheel_path = wheel_dir / wheel_name
    if wheel_path.exists():
        wheel_path.unlink()

    with zipfile.ZipFile(wheel_path, "w", zipfile.ZIP_DEFLATED) as zf:
        for path in sorted(stage.rglob("*")):
            if path.is_file():
                arcname = path.relative_to(stage).as_posix()
                info = wheel_info_for_file(path, arcname)
                info.compress_type = zipfile.ZIP_DEFLATED
                zf.writestr(info, path.read_bytes())

    print(f"Built {wheel_path}")
    return wheel_path


def main():
    parser = argparse.ArgumentParser(
        description="Package a patched CPython runtime as a PyPI wheel."
    )
    parser.add_argument("version")
    parser.add_argument("target")
    parser.add_argument("runtime_root", type=Path)
    parser.add_argument(
        "--wheel-dir",
        type=Path,
        default=Path("build/wheelhouse"),
        help="Directory for the output wheel.",
    )
    args = parser.parse_args()

    build_wheel(args.version, args.target, args.runtime_root, args.wheel_dir)


if __name__ == "__main__":
    main()
