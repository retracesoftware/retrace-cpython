#!/usr/bin/env python3
import argparse
import re
import sys
from pathlib import Path


VERSION_RE = re.compile(
    r"^v?(?P<major>[0-9]+)"
    r"(?:\.(?P<minor>[0-9]+))?"
    r"(?:\.(?P<point>[0-9]+))?"
    r"(?:\.post[0-9]+)?$"
)


def parse_version(value):
    match = VERSION_RE.fullmatch(value.strip())
    if match is None:
        return None
    major = int(match.group("major"))
    minor = int(match.group("minor") or 0)
    point = int(match.group("point") or 0)
    return major, minor, point


def format_version(version):
    return ".".join(str(part) for part in version)


def bump_version(version, bump):
    major, minor, point = version
    if bump == "major":
        return major + 1, 0, 0
    if bump == "minor":
        return major, minor + 1, 0
    if bump in {"point", "patch"}:
        return major, minor, point + 1
    raise SystemExit(f"unsupported bump kind: {bump}")


def main():
    parser = argparse.ArgumentParser(
        description=(
            "Resolve the next retracesoftware-cpython package version from "
            "the checked-in VERSION file."
        )
    )
    parser.add_argument(
        "bump",
        choices=("major", "minor", "point", "patch"),
        help="Version component to bump. 'patch' is accepted as an alias for 'point'.",
    )
    parser.add_argument(
        "--current-version",
        help="Use this version instead of reading VERSION; useful for local checks.",
    )
    parser.add_argument(
        "--version-file",
        type=Path,
        default=Path("VERSION"),
        help="Version file to read when --current-version is not set.",
    )
    args = parser.parse_args()

    if args.current_version:
        current = parse_version(args.current_version)
        if current is None:
            raise SystemExit(f"unsupported current version: {args.current_version}")
    else:
        if not args.version_file.is_file():
            raise SystemExit(f"version file does not exist: {args.version_file}")
        current_text = args.version_file.read_text(encoding="utf-8").strip()
        current = parse_version(current_text)
        if current is None:
            raise SystemExit(f"unsupported version in {args.version_file}: {current_text}")

    next_version = bump_version(current, args.bump)
    print(format_version(next_version))
    print(
        f"Resolved package version {format_version(next_version)} "
        f"from {format_version(current)} with {args.bump} bump",
        file=sys.stderr,
    )


if __name__ == "__main__":
    main()
