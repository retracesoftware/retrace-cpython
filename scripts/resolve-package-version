#!/usr/bin/env python3
import argparse
import json
import re
import sys
import urllib.error
import urllib.request


PROJECT_NAME = "retracesoftware-cpython"
DEFAULT_INDEX_URL = "https://pypi.org/pypi"
VERSION_RE = re.compile(
    r"^v?(?P<major>[0-9]+)"
    r"(?:\.(?P<minor>[0-9]+))?"
    r"(?:\.(?P<point>[0-9]+))?"
    r"(?:\.post[0-9]+)?$"
)


def parse_version(value):
    match = VERSION_RE.fullmatch(value.strip())
    if match is None:
        return None
    major = int(match.group("major"))
    minor = int(match.group("minor") or 0)
    point = int(match.group("point") or 0)
    return major, minor, point


def format_version(version):
    return ".".join(str(part) for part in version)


def fetch_versions(project, index_url):
    url = f"{index_url.rstrip('/')}/{project}/json"
    try:
        with urllib.request.urlopen(url, timeout=15) as response:
            data = json.load(response)
    except urllib.error.HTTPError as exc:
        if exc.code == 404:
            return []
        raise

    return list((data.get("releases") or {}).keys())


def latest_release(versions):
    parsed = [parse_version(version) for version in versions]
    parsed = [version for version in parsed if version is not None]
    if not parsed:
        return 0, 0, 0
    return max(parsed)


def bump_version(version, bump):
    major, minor, point = version
    if bump == "major":
        return major + 1, 0, 0
    if bump == "minor":
        return major, minor + 1, 0
    if bump in {"point", "patch"}:
        return major, minor, point + 1
    raise SystemExit(f"unsupported bump kind: {bump}")


def main():
    parser = argparse.ArgumentParser(
        description="Resolve the next retracesoftware-cpython package version."
    )
    parser.add_argument(
        "bump",
        choices=("major", "minor", "point", "patch"),
        help="Version component to bump. 'patch' is accepted as an alias for 'point'.",
    )
    parser.add_argument("--project", default=PROJECT_NAME)
    parser.add_argument("--index-url", default=DEFAULT_INDEX_URL)
    parser.add_argument(
        "--current-version",
        help="Use this version instead of querying PyPI; useful for local checks.",
    )
    args = parser.parse_args()

    if args.current_version:
        current = parse_version(args.current_version)
        if current is None:
            raise SystemExit(f"unsupported current version: {args.current_version}")
    else:
        current = latest_release(fetch_versions(args.project, args.index_url))

    next_version = bump_version(current, args.bump)
    print(format_version(next_version))
    print(
        f"Resolved package version {format_version(next_version)} "
        f"from {format_version(current)} with {args.bump} bump",
        file=sys.stderr,
    )


if __name__ == "__main__":
    main()
