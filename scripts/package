#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
usage: scripts/package VERSION [PREFIX]

Package an installed retrace-cpython prefix as a tar.gz archive.
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -lt 1 || $# -gt 2 ]]; then
  usage >&2
  exit 2
fi

version="${1#v}"
repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
prefix="${2:-${repo_root}/build/install/${version}+retrace}"

if [[ ! -d "${prefix}" ]]; then
  echo "Install prefix does not exist: ${prefix}" >&2
  exit 1
fi

platform="$(uname -s | tr '[:upper:]' '[:lower:]')-$(uname -m)"
dist_dir="${repo_root}/build/dist"
archive="${dist_dir}/retrace-cpython-${version}-${platform}.tar.gz"

mkdir -p "${dist_dir}"
tar -C "$(dirname "${prefix}")" -czf "${archive}" "$(basename "${prefix}")"

echo "${archive}"

