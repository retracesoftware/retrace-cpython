#!/usr/bin/env python3
import argparse
import os
import subprocess
from pathlib import Path


def run(command, env):
    print("+", " ".join(str(part) for part in command))
    subprocess.run(command, env=env, check=True)


def main():
    parser = argparse.ArgumentParser(
        description="Run a patched Python executable against a vanilla Python home."
    )
    parser.add_argument("patched_python", type=Path)
    parser.add_argument("vanilla_home", type=Path)
    parser.add_argument("smoke_scripts", nargs="+", type=Path)
    parser.add_argument("--version", required=True)
    args = parser.parse_args()

    patched_python = args.patched_python.resolve()
    vanilla_home = args.vanilla_home.resolve()
    smoke_scripts = [script.resolve() for script in args.smoke_scripts]

    if not patched_python.is_file():
        raise SystemExit(f"patched executable does not exist: {patched_python}")
    if not vanilla_home.exists():
        raise SystemExit(f"vanilla Python home does not exist: {vanilla_home}")
    for smoke_script in smoke_scripts:
        if not smoke_script.is_file():
            raise SystemExit(f"smoke script does not exist: {smoke_script}")

    env = os.environ.copy()
    env["PYTHONHOME"] = str(vanilla_home)
    env["RETRACE_EXPECTED_VERSION"] = args.version

    check = r"""
import importlib.util
import os
import sys

expected_version = os.environ["RETRACE_EXPECTED_VERSION"]
if sys.version.split()[0] != expected_version:
    raise SystemExit(
        f"version mismatch: expected {expected_version}, got {sys.version.split()[0]}"
    )

expected_home = os.path.normcase(os.path.abspath(os.environ["PYTHONHOME"]))

def under_home(path):
    actual = os.path.normcase(os.path.abspath(path))
    try:
        return os.path.commonpath([actual, expected_home]) == expected_home
    except ValueError:
        return False

if importlib.util.find_spec("_retrace") is None:
    raise SystemExit("_retrace module is not importable")
if "_retrace" not in sys.builtin_module_names:
    raise SystemExit("_retrace module is not built in")

import encodings
import json
import threading

for module in (encodings, json):
    if not under_home(module.__file__):
        raise SystemExit(
            f"{module.__name__} loaded outside PYTHONHOME: {module.__file__!r}"
        )

print(f"vanilla_home={expected_home}")
print(f"sys_prefix={sys.prefix}")
print(f"stdlib_json={json.__file__}")
print("_retrace_module=builtin")
"""

    run([str(patched_python), "-c", check], env)
    for smoke_script in smoke_scripts:
        run([str(patched_python), str(smoke_script)], env)


if __name__ == "__main__":
    main()
