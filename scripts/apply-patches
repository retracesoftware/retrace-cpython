#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
usage: scripts/apply-patches VERSION [DEST]

Clone or reset CPython at tag vVERSION, then apply the matching Retrace patch
stack. VERSION should normally be an exact CPython release such as 3.12.8.

Environment:
  CPYTHON_REPO_URL  source remote, default https://github.com/python/cpython.git
  PYTHON            Python used to read patch manifests, default python3
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -lt 1 || $# -gt 2 ]]; then
  usage >&2
  exit 2
fi

version="${1#v}"
tag="v${version}"
dest="${2:-build/src/cpython-${version}+retrace}"
repo_url="${CPYTHON_REPO_URL:-https://github.com/python/cpython.git}"
repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
python_bin="${PYTHON:-python3}"

IFS=. read -r major minor _patch <<<"${version}"
if [[ -z "${major:-}" || -z "${minor:-}" ]]; then
  echo "VERSION must include at least major.minor, got: ${version}" >&2
  exit 2
fi

exact_patch_dir="${repo_root}/patches/${version}"
minor_patch_dir="${repo_root}/patches/${major}.${minor}"

if [[ -d "${exact_patch_dir}" ]]; then
  patch_dir="${exact_patch_dir}"
elif [[ -d "${minor_patch_dir}" ]]; then
  patch_dir="${minor_patch_dir}"
else
  echo "No patch directory found for ${version}." >&2
  echo "Expected ${exact_patch_dir} or ${minor_patch_dir}." >&2
  exit 1
fi

manifest="${patch_dir}/series.toml"

if [[ -f "${manifest}" ]]; then
  patch_list="$("${python_bin}" - "${manifest}" "${version}" "${patch_dir}" <<'PY'
import operator
import pathlib
import re
import sys
import tomllib

manifest = pathlib.Path(sys.argv[1])
version = sys.argv[2]
patch_dir = pathlib.Path(sys.argv[3])

data = tomllib.loads(manifest.read_text())

def parse_version(value):
    value = value.removeprefix("v")
    parts = value.split(".")
    if not parts or len(parts) > 3:
        raise ValueError(f"unsupported version: {value!r}")
    parsed = []
    for part in parts:
        if not part.isdigit():
            raise ValueError(f"unsupported version: {value!r}")
        parsed.append(int(part))
    return tuple(parsed + [0] * (3 - len(parsed)))

ops = {
    "<": operator.lt,
    "<=": operator.le,
    "==": operator.eq,
    ">=": operator.ge,
    ">": operator.gt,
}

spec = data.get("python")
if spec:
    try:
        requested = parse_version(version)
    except ValueError as exc:
        raise SystemExit(f"{manifest}: {exc}") from exc
    for clause in (part.strip() for part in spec.split(",")):
        if not clause:
            continue
        match = re.fullmatch(r"(<=|>=|==|<|>)([0-9]+(?:\.[0-9]+){0,2})", clause)
        if match is None:
            raise SystemExit(f"{manifest}: unsupported python range clause {clause!r}")
        op, bound = match.groups()
        try:
            parsed_bound = parse_version(bound)
        except ValueError as exc:
            raise SystemExit(f"{manifest}: {exc}") from exc
        if not ops[op](requested, parsed_bound):
            raise SystemExit(
                f"{manifest}: CPython {version} is outside supported range {spec!r}"
            )

patches = data.get("patches")
if not isinstance(patches, list):
    raise SystemExit(f"{manifest}: patches must be a list")

for patch in patches:
    if not isinstance(patch, str):
        raise SystemExit(f"{manifest}: patch entries must be strings")
    path = patch_dir / patch
    if not path.is_file():
        raise SystemExit(f"{manifest}: listed patch does not exist: {patch}")
    print(path)
PY
  )"
  patches=()
  if [[ -n "${patch_list}" ]]; then
    while IFS= read -r patch; do
      patch="${patch%$'\r'}"
      patches+=("${patch}")
    done <<<"${patch_list}"
  fi
else
  shopt -s nullglob
  patches=("${patch_dir}"/*.patch)
fi

mkdir -p "$(dirname "${dest}")"

if [[ -d "${dest}/.git" ]]; then
  git -C "${dest}" fetch --tags --force origin "${tag}"
  git -C "${dest}" checkout -B "retrace-${version}" "${tag}"
  git -C "${dest}" reset --hard "${tag}"
  git -C "${dest}" clean -fdx
else
  if [[ -e "${dest}" ]]; then
    echo "Destination exists but is not a git checkout: ${dest}" >&2
    exit 1
  fi
  git clone --branch "${tag}" --depth 1 "${repo_url}" "${dest}"
  git -C "${dest}" checkout -B "retrace-${version}" "${tag}"
fi

git -C "${dest}" config user.name "Retrace CPython Builder"
git -C "${dest}" config user.email "retrace-cpython@retracesoftware.com"

if (( ${#patches[@]} == 0 )); then
  echo "No patches found in ${patch_dir}; checkout remains vanilla ${tag}."
else
  if ! git -C "${dest}" am "${patches[@]}"; then
    git -C "${dest}" am --abort || true
    git -C "${dest}" reset --hard "${tag}"
    git -C "${dest}" clean -fdx
    git -C "${dest}" am --3way "${patches[@]}"
  fi
fi

overlay_dir="${repo_root}/cpython-overlay"
if [[ -d "${overlay_dir}" ]]; then
  while IFS= read -r -d '' overlay_file; do
    rel="${overlay_file#${overlay_dir}/}"
    mkdir -p "${dest}/$(dirname "${rel}")"
    cp "${overlay_file}" "${dest}/${rel}"
  done < <(find "${overlay_dir}" -type f -print0)
fi

echo "Prepared ${dest}"
echo "CPython tag: ${tag}"
echo "Patch dir: ${patch_dir}"
if [[ -f "${manifest}" ]]; then
  echo "Patch manifest: ${manifest}"
fi
if [[ -d "${overlay_dir}" ]]; then
  echo "Overlay dir: ${overlay_dir}"
fi
