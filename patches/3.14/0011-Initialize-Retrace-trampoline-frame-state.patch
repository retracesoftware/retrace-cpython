From: Retrace CPython Builder <retrace-cpython@retracesoftware.com>
Date: Thu, 14 May 2026 14:19:55 +0100
Subject: [PATCH] Initialize Retrace trampoline frame state

---
 Include/internal/pycore_interpframe.h | 1 +
 1 file changed, 1 insertion(+)

diff --git a/Include/internal/pycore_interpframe.h b/Include/internal/pycore_interpframe.h
index fd95a00..7b00f67 100644
--- a/Include/internal/pycore_interpframe.h
+++ b/Include/internal/pycore_interpframe.h
@@ -393,6 +393,7 @@ _PyFrame_PushTrampolineUnchecked(PyThreadState *tstate, PyCodeObject *code, int
     frame->lltrace = 0;
 #endif
     frame->return_offset = 0;
+    _PyRetraceFrameState_Init(&frame->retrace);
     return frame;
 }
 
