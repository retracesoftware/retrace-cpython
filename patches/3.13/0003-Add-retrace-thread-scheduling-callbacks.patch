From bc37f0d537b0f573a77ca7e98e6435c0bdcbf630 Mon Sep 17 00:00:00 2001
From: Retrace CPython Builder <retrace-cpython@retracesoftware.com>
Date: Thu, 7 May 2026 09:50:42 +0100
Subject: [PATCH 3/9] Add retrace thread scheduling callbacks

---
 Include/cpython/pystate.h        |  4 ++++
 Include/internal/pycore_interp.h |  3 +++
 Modules/_threadmodule.c          | 39 ++++++++++++++++++++++-----------------
 Modules/signalmodule.c           |  3 +++
 Python/ceval.c                   |  1 +
 Python/ceval_gil.c               | 13 +++++++++++++
 Python/ceval_macros.h            |  6 ++++-
 Python/pystate.c                 | 14 +++++++++++---
 8 files changed, 62 insertions(+), 21 deletions(-)

diff --git a/Include/cpython/pystate.h b/Include/cpython/pystate.h
index 72a4969a2ad..979ca24a5ea 100644
--- a/Include/cpython/pystate.h
+++ b/Include/cpython/pystate.h
@@ -2,6 +2,8 @@
 #  error "this header file must not be included directly"
 #endif

+#include "cpython/retrace_state.h" // _PyRetraceThreadState
+

 /* private interpreter helpers */

@@ -199,4 +201,6 @@ struct _ts {
     /* Used by `threading.local`s to be remove keys/values for dying threads.
        The PyThreadObject must hold the only reference to this value.
     */
+
+    _PyRetraceThreadState retrace;
     PyObject *threading_local_sentinel;
diff --git a/Include/internal/pycore_interp.h b/Include/internal/pycore_interp.h
index 3243b1e618d..3fd999295bd 100644
--- a/Include/internal/pycore_interp.h
+++ b/Include/internal/pycore_interp.h
@@ -38,6 +38,7 @@ extern "C" {
 #include "pycore_typeobject.h"    // struct types_state
 #include "pycore_unicodeobject.h" // struct _Py_unicode_state
 #include "pycore_warnings.h"      // struct _warnings_runtime_state
+#include "cpython/retrace_state.h" // _PyRetraceInterpreterState


 struct _Py_long_state {
@@ -236,6 +237,8 @@ struct _is {
     struct _obmalloc_state *obmalloc;

     PyObject *audit_hooks;
+
+    _PyRetraceInterpreterState retrace;
     PyType_WatchCallback type_watchers[TYPE_MAX_WATCHERS];
     PyCode_WatchCallback code_watchers[CODE_MAX_WATCHERS];
     // One bit is set for each non-NULL entry in code_watchers
diff --git a/Modules/_threadmodule.c b/Modules/_threadmodule.c
index bc9433afe41..3c88f3592c4 100644
--- a/Modules/_threadmodule.c
+++ b/Modules/_threadmodule.c
@@ -2,6 +2,7 @@
 /* Interface to Sjoerd's portable C thread library */

 #include "Python.h"
+#include "pycore_retrace.h"       // retrace thread helpers
 #include "pycore_interp.h"        // _PyInterpreterState.threads.count
 #include "pycore_lock.h"
 #include "pycore_moduleobject.h"  // _PyModule_GetState()
@@ -384,7 +385,7 @@ force_done(ThreadHandle *handle)

 static int
 ThreadHandle_start(ThreadHandle *self, PyObject *func, PyObject *args,
-                   PyObject *kwargs)
+                   PyObject *kwargs, uint64_t *retrace_thread_id)
 {
     // Mark the handle as starting to prevent any other threads from doing so
     PyMutex_Lock(&self->mutex);
@@ -432,6 +433,10 @@ ThreadHandle_start(ThreadHandle *self, PyObject *func, PyObject *args,
         PyErr_SetString(ThreadError, "can't start new thread");
         goto start_failed;
     }
+    _PyRetrace_RegisterThreadIdent(boot->tstate, (unsigned long)ident);
+    if (retrace_thread_id != NULL) {
+        *retrace_thread_id = boot->tstate->retrace.thread_id;
+    }

     // Mark the handle running
     PyMutex_Lock(&self->mutex);
@@ -1833,7 +1838,8 @@ and False otherwise.\n");

 static int
 do_start_new_thread(thread_module_state *state, PyObject *func, PyObject *args,
-                    PyObject *kwargs, ThreadHandle *handle, int daemon)
+                    PyObject *kwargs, ThreadHandle *handle, int daemon,
+                    uint64_t *retrace_thread_id)
 {
     PyInterpreterState *interp = _PyInterpreterState_GET();
     if (!_PyInterpreterState_HasFeature(interp, Py_RTFLAGS_THREADS)) {
@@ -1854,7 +1860,7 @@ do_start_new_thread(thread_module_state *state, PyObject *func, PyObject *args,
         add_to_shutdown_handles(state, handle);
     }

-    if (ThreadHandle_start(handle, func, args, kwargs) < 0) {
+    if (ThreadHandle_start(handle, func, args, kwargs, retrace_thread_id) < 0) {
         if (!daemon) {
             remove_from_shutdown_handles(handle);
         }
@@ -1899,15 +1905,16 @@ thread_PyThread_start_new_thread(PyObject *module, PyObject *fargs)
         return NULL;
     }

+    uint64_t retrace_thread_id = 0;
     int st =
-        do_start_new_thread(state, func, args, kwargs, handle, /*daemon=*/1);
+        do_start_new_thread(state, func, args, kwargs, handle, /*daemon=*/1,
+                            &retrace_thread_id);
     if (st < 0) {
         ThreadHandle_decref(handle);
         return NULL;
     }
-    PyThread_ident_t ident = ThreadHandle_ident(handle);
     ThreadHandle_decref(handle);
-    return PyLong_FromUnsignedLongLong(ident);
+    return PyLong_FromUnsignedLongLong((unsigned long long)retrace_thread_id);
 }

 PyDoc_STRVAR(start_new_thread_doc,
@@ -1978,7 +1985,8 @@ thread_PyThread_start_joinable_thread(PyObject *module, PyObject *fargs,
         return NULL;
     }
     int st = do_start_new_thread(state, func, args,
-                                 /*kwargs=*/ NULL, ((PyThreadHandleObject*)hobj)->handle, daemon);
+                                 /*kwargs=*/ NULL, ((PyThreadHandleObject*)hobj)->handle, daemon,
+                                 NULL);
     Py_DECREF(args);
     if (st < 0) {
         Py_DECREF(hobj);
@@ -2070,12 +2078,7 @@ An obsolete synonym of allocate_lock().");
 static PyObject *
 thread_get_ident(PyObject *self, PyObject *Py_UNUSED(ignored))
 {
-    PyThread_ident_t ident = PyThread_get_thread_ident_ex();
-    if (ident == PYTHREAD_INVALID_THREAD_ID) {
-        PyErr_SetString(ThreadError, "no current thread ident");
-        return NULL;
-    }
-    return PyLong_FromUnsignedLongLong(ident);
+    return _PyRetrace_ThreadIdentObject(_PyThreadState_GET());
 }

 PyDoc_STRVAR(get_ident_doc,
@@ -2204,8 +2207,12 @@ thread_excepthook_file(PyObject *file, PyObject *exc_type, PyObject *exc_value,
         Py_DECREF(name);
     }
     else {
-        PyThread_ident_t ident = PyThread_get_thread_ident_ex();
-        PyObject *str = PyUnicode_FromFormat("%" PY_FORMAT_THREAD_IDENT_T, ident);
+        PyObject *ident = _PyRetrace_ThreadIdentObject(_PyThreadState_GET());
+        if (ident == NULL) {
+            PyErr_Clear();
+        }
+        PyObject *str = ident == NULL ? NULL : PyObject_Str(ident);
+        Py_XDECREF(ident);
         if (str != NULL) {
             if (PyFile_WriteObject(str, file, Py_PRINT_RAW) < 0) {
                 Py_DECREF(str);
@@ -2214,8 +2221,6 @@ thread_excepthook_file(PyObject *file, PyObject *exc_type, PyObject *exc_value,
             Py_DECREF(str);
         }
         else {
-            PyErr_Clear();
-
             if (PyFile_WriteString("<failed to get thread name>", file) < 0) {
                 return -1;
             }
diff --git a/Modules/signalmodule.c b/Modules/signalmodule.c
index 6f53dcda824..3e7a9e0ff57 100644
--- a/Modules/signalmodule.c
+++ b/Modules/signalmodule.c
@@ -12,6 +12,7 @@
 #include "pycore_moduleobject.h"  // _PyModule_GetState()
 #include "pycore_pyerrors.h"      // _PyErr_SetString()
 #include "pycore_pystate.h"       // _PyThreadState_GET()
+#include "pycore_retrace.h"       // retrace thread helpers
 #include "pycore_signal.h"        // _Py_RestoreSignals()
 #include "pycore_time.h"          // _PyTime_FromSecondsObject()

@@ -1288,6 +1289,8 @@ signal_pthread_kill_impl(PyObject *module, unsigned long thread_id,
         return NULL;
     }

+    thread_id = _PyRetrace_CPythonThreadIdentFromPublicIdent(
+        _PyInterpreterState_GET(), thread_id);
     err = pthread_kill((pthread_t)thread_id, signalnum);
     if (err != 0) {
         errno = err;
diff --git a/Python/ceval.c b/Python/ceval.c
index ca23e298792..ad70ea1bc12 100644
--- a/Python/ceval.c
+++ b/Python/ceval.c
@@ -3,6 +3,7 @@
 #define _PY_INTERPRETER

 #include "Python.h"
+#include "pycore_retrace.h"       // thread scheduling callbacks
 #include "pycore_abstract.h"      // _PyIndex_Check()
 #include "pycore_backoff.h"
 #include "pycore_call.h"          // _PyObject_CallNoArgs()
diff --git a/Python/ceval_gil.c b/Python/ceval_gil.c
index a1433e5b25f..4902440e01a 100644
--- a/Python/ceval_gil.c
+++ b/Python/ceval_gil.c
@@ -7,2 +7,3 @@
 #include "pycore_pylifecycle.h"   // _PyErr_Print()
+#include "pycore_retrace.h"       // thread scheduling callbacks
 #include "pycore_pymem.h"         // _PyMem_IsPtrFreed()
@@ -389,6 +390,7 @@ take_gil(PyThreadState *tstate)
     if (tstate != (PyThreadState*)_Py_atomic_load_ptr_relaxed(&gil->last_holder)) {
         _Py_atomic_store_ptr_relaxed(&gil->last_holder, tstate);
         ++gil->switch_number;
+        _PyRetrace_NoteThreadResume(tstate);
     }

 #ifdef FORCE_SWITCHING
@@ -573,6 +575,7 @@ PyEval_AcquireLock(void)
     _Py_EnsureTstateNotNULL(tstate);

     take_gil(tstate);
+    _PyRetrace_DeliverThreadResumeCallback(tstate, NULL);
 }

 // Function removed in the Python 3.13 API but kept in the stable ABI.
@@ -583,6 +586,8 @@ PyEval_ReleaseLock(void)
     /* This function must succeed when the current thread state is NULL.
        We therefore avoid PyThreadState_Get() which dumps a fatal error
        in debug mode. */
+    (void)_PyRetrace_PinThreadCallbackFrame(
+        tstate, _PyRetrace_CurrentThreadFrame(tstate));
     drop_gil(tstate->interp, tstate, 0);
 }

@@ -600,6 +606,8 @@ _PyEval_ReleaseLock(PyInterpreterState *interp,
 {
     assert(tstate != NULL);
     assert(tstate->interp == interp);
+    (void)_PyRetrace_PinThreadCallbackFrame(
+        tstate, _PyRetrace_CurrentThreadFrame(tstate));
     drop_gil(interp, tstate, final_release);
 }

@@ -614,6 +622,8 @@ void
 PyEval_ReleaseThread(PyThreadState *tstate)
 {
     assert(_PyThreadState_CheckConsistency(tstate));
+    (void)_PyRetrace_PinThreadCallbackFrame(
+        tstate, _PyRetrace_CurrentThreadFrame(tstate));
     _PyThreadState_Detach(tstate);
 }

@@ -644,6 +654,9 @@ PyThreadState *
 PyEval_SaveThread(void)
 {
     PyThreadState *tstate = _PyThreadState_GET();
+    _Py_EnsureTstateNotNULL(tstate);
+    (void)_PyRetrace_PinThreadCallbackFrame(
+        tstate, _PyRetrace_CurrentThreadFrame(tstate));
     _PyThreadState_Detach(tstate);
     return tstate;
 }
@@ -1311,6 +1324,7 @@ _Py_HandlePending(PyThreadState *tstate)
     /* GIL drop request */
     if ((breaker & _PY_GIL_DROP_REQUEST_BIT) != 0) {
         /* Give another thread a chance */
+        _PyRetrace_DeliverThreadYieldCallback(tstate, NULL);
         _PyThreadState_Detach(tstate);

         /* Other threads may run now */
diff --git a/Python/ceval_macros.h b/Python/ceval_macros.h
index ef684e88ccb..83c25695c6a 100644
--- a/Python/ceval_macros.h
+++ b/Python/ceval_macros.h
@@ -137,7 +137,11 @@ do { \
     _Py_CHECK_EMSCRIPTEN_SIGNALS_PERIODICALLY(); \
     QSBR_QUIESCENT_STATE(tstate); \
     if (_Py_atomic_load_uintptr_relaxed(&tstate->eval_breaker) & _PY_EVAL_EVENTS_MASK) { \
-        if (_Py_HandlePending(tstate) != 0) { \
+        _PyInterpreterFrame *retrace_callback_frame = \
+            _PyRetrace_PinThreadCallbackFrame(tstate, frame); \
+        int retrace_pending_err = _Py_HandlePending(tstate); \
+        _PyRetrace_RestoreThreadCallbackFrame(tstate, retrace_callback_frame); \
+        if (retrace_pending_err != 0) { \
             GOTO_ERROR(error); \
         } \
     }
diff --git a/Python/pystate.c b/Python/pystate.c
index 07c69b92d52..330ec7418b7 100644
--- a/Python/pystate.c
+++ b/Python/pystate.c
@@ -16,6 +16,7 @@
 #include "pycore_pyerrors.h"      // _PyErr_Clear()
 #include "pycore_pylifecycle.h"   // _PyAST_Fini()
 #include "pycore_pymem.h"         // _PyMem_SetDefaultAllocator()
+#include "pycore_retrace.h"       // thread-state helpers
 #include "pycore_pystate.h"
 #include "pycore_runtime_init.h"  // _PyRuntimeState_INIT
 #include "pycore_sysmodule.h"     // _PySys_Audit()
@@ -821,6 +822,9 @@ interpreter_clear(PyInterpreterState *interp, PyThreadState *tstate)
     // XXX Make sure we properly deal with problematic finalizers.

     Py_CLEAR(interp->audit_hooks);
+    Py_CLEAR(interp->retrace.thread_start_callback);
+    Py_CLEAR(interp->retrace.thread_yield_callback);
+    Py_CLEAR(interp->retrace.thread_resume_callback);

     // At this time, all the threads should be cleared so we don't need atomic
     // operations for instrumentation_version or eval_breaker.
@@ -1536,6 +1540,7 @@ init_threadstate(_PyThreadStateImpl *_tstate,
         // Start in the suspended state if there is an ongoing stop-the-world.
         tstate->state = _Py_THREAD_SUSPENDED;
     }
+    _PyRetrace_InitializeThreadState(interp, tstate);

     tstate->_status.initialized = 1;
 }
@@ -1582,6 +1587,7 @@ new_threadstate(PyInterpreterState *interp, int whence)
     // Add the new thread state to the interpreter.
     PyThreadState *old_head = interp->threads.head;
     add_threadstate(interp, (PyThreadState *)tstate, old_head);
+    _PyRetrace_SeedThreadState(current_fast_get(), (PyThreadState *)tstate);

     HEAD_UNLOCK(interp->runtime);
 #ifdef Py_GIL_DISABLED
@@ -1741,6 +1747,7 @@ PyThreadState_Clear(PyThreadState *tstate)
     Py_CLEAR(tstate->async_gen_finalizer);

     Py_CLEAR(tstate->context);
+    _PyRetrace_ClearThreadState(tstate);

 #ifdef Py_GIL_DISABLED
     // Each thread should clear own freelists in free-threading builds.
@@ -2138,9 +2145,10 @@ _PyThreadState_Attach(PyThreadState *tstate)
     // Resume previous critical section. This acquires the lock(s) from the
     // top-most critical section.
     if (tstate->critical_section != 0) {
         _PyCriticalSection_Resume(tstate);
     }
+    _PyRetrace_DeliverThreadResumeCallback(tstate, NULL);

 #if defined(Py_DEBUG)
     errno = err;
 #endif
@@ -2397,7 +2404,7 @@ PyThreadState_SetAsyncExc(unsigned long id, PyObject *exc)
      */
     HEAD_LOCK(runtime);
     for (PyThreadState *tstate = interp->threads.head; tstate != NULL; tstate = tstate->next) {
-        if (tstate->thread_id != id) {
+        if (!_PyRetrace_ThreadMatchesAsyncExcId(interp, tstate, id)) {
             continue;
         }

@@ -2564,7 +2571,7 @@ _PyThread_CurrentFrames(void)
             if (frame == NULL) {
                 continue;
             }
-            PyObject *id = PyLong_FromUnsignedLong(t->thread_id);
+            PyObject *id = _PyRetrace_ThreadIdentObject(t);
             if (id == NULL) {
                 goto fail;
             }
@@ -2629,7 +2636,7 @@ _PyThread_CurrentExceptions(void)
             if (err_info == NULL) {
                 continue;
             }
-            PyObject *id = PyLong_FromUnsignedLong(t->thread_id);
+            PyObject *id = _PyRetrace_ThreadIdentObject(t);
             if (id == NULL) {
                 goto fail;
             }
