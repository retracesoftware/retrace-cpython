From 7a03762e4eb54ac54b9743d80cb64c77c4353a9f Mon Sep 17 00:00:00 2001
From: Retrace CPython Builder <retrace-cpython@retracesoftware.com>
Date: Thu, 7 May 2026 09:50:41 +0100
Subject: [PATCH 1/9] Add Retrace coordinate bias to interpreter frames

---
 Include/internal/pycore_frame.h |  3 +++
 Python/ceval.c                  |  5 +++++
 Python/ceval_macros.h           | 10 ++++++++--
 3 files changed, 16 insertions(+), 2 deletions(-)

diff --git a/Include/internal/pycore_frame.h b/Include/internal/pycore_frame.h
index a6bd971ea0c..54163a34a6a 100644
--- a/Include/internal/pycore_frame.h
+++ b/Include/internal/pycore_frame.h
@@ -10,4 +10,5 @@ extern "C" {

 #include <stdbool.h>
 #include <stddef.h>               // offsetof()
+#include "cpython/retrace_state.h" // _PyRetraceFrameState
 #include "pycore_code.h"          // STATS
@@ -71,6 +72,7 @@ typedef struct _PyInterpreterFrame {
     int stacktop;  /* Offset of TOS from localsplus  */
     uint16_t return_offset;  /* Only relevant during a function call */
     char owner;
+    _PyRetraceFrameState retrace;
     /* Locals and stack */
     PyObject *localsplus[1];
 } _PyInterpreterFrame;
@@ -185,6 +187,7 @@ _PyFrame_Initialize(
     frame->instr_ptr = _PyCode_CODE(code);
     frame->return_offset = 0;
     frame->owner = FRAME_OWNED_BY_THREAD;
+    _PyRetraceFrameState_Init(&frame->retrace);

     for (int i = null_locals_from; i < code->co_nlocalsplus; i++) {
         frame->localsplus[i] = NULL;
diff --git a/Python/ceval.c b/Python/ceval.c
index 7a4e704a4b5..ca23e298792 100644
--- a/Python/ceval.c
+++ b/Python/ceval.c
@@ -718,9 +718,12 @@ _PyEval_EvalFrameDefault(PyThreadState *tstate, _PyInterpreterFrame *frame, int
     entry_frame.stacktop = 0;
     entry_frame.owner = FRAME_OWNED_BY_CSTACK;
     entry_frame.return_offset = 0;
+    _PyRetraceFrameState_Init(&entry_frame.retrace);
+    _PyFrame_RetraceInitializeLastCoordinate(&entry_frame);
     /* Push frame */
     entry_frame.previous = tstate->current_frame;
     frame->previous = &entry_frame;
+    _PyFrame_RetraceResetLastCoordinate(frame);
     tstate->current_frame = frame;

     tstate->c_recursion_remaining -= (PY_EVAL_C_STACK_UNITS - 1);
@@ -735,6 +738,7 @@ _PyEval_EvalFrameDefault(PyThreadState *tstate, _PyInterpreterFrame *frame, int
         if (_Py_EnterRecursivePy(tstate)) {
             goto exit_unwind;
         }
+        _PyRetrace_ActivateFrame(tstate, frame);
         /* Because this avoids the RESUME,
          * we need to update instrumentation */
         _Py_Instrument(_PyFrame_GetCode(frame), tstate->interp);
@@ -758,6 +762,7 @@ _PyEval_EvalFrameDefault(PyThreadState *tstate, _PyInterpreterFrame *frame, int
     if (_Py_EnterRecursivePy(tstate)) {
         goto exit_unwind;
     }
+    _PyRetrace_ActivateFrame(tstate, frame);

     next_instr = frame->instr_ptr;
 resume_frame:
@@ -930,3 +935,5 @@ _PyEval_EvalFrameDefault(PyThreadState *tstate, _PyInterpreterFrame *frame, int
-            next_instr = _PyCode_CODE(_PyFrame_GetCode(frame)) + handler;
-
+            _Py_CODEUNIT *target = _PyCode_CODE(_PyFrame_GetCode(frame)) + handler;
+            _PyFrame_RetraceCoordinateJump(frame, frame->instr_ptr, target);
+            next_instr = target;
+
             if (monitor_handled(tstate, frame, next_instr, exc) < 0) {
diff --git a/Python/ceval_macros.h b/Python/ceval_macros.h
index 1ab83856fd9..ef684e88ccb 100644
--- a/Python/ceval_macros.h
+++ b/Python/ceval_macros.h
@@ -170,6 +170,11 @@ GETITEM(PyObject *v, Py_ssize_t i) {
 /* JUMPBY makes the generator identify the instruction as a jump. SKIP_OVER is
  * for advancing to the next instruction, taking into account cache entries
  * and skipped instructions.
  */
-#define JUMPBY(x)       (next_instr += (x))
+#define JUMPBY(x) \
+    do { \
+        _Py_CODEUNIT *target = next_instr + (x); \
+        _PyFrame_RetraceCoordinateJump(frame, frame->instr_ptr, target); \
+        next_instr = target; \
+    } while (0)
 #define SKIP_OVER(x)    (next_instr += (x))
@@ -357,17 +362,19 @@ do { \
 // If a trace function sets a new f_lineno and
 // *then* raises, we use the destination when searching
 // for an exception handler, displaying the traceback, and so on
 #define INSTRUMENTED_JUMP(src, dest, event) \
 do { \
+    _Py_CODEUNIT *retrace_jump_src = (src); \
     if (tstate->tracing) {\
         next_instr = dest; \
     } else { \
         _PyFrame_SetStackPointer(frame, stack_pointer); \
         next_instr = _Py_call_instrumentation_jump(tstate, event, frame, src, dest); \
         stack_pointer = _PyFrame_GetStackPointer(frame); \
         if (next_instr == NULL) { \
             next_instr = (dest)+1; \
             goto error; \
         } \
     } \
+    _PyFrame_RetraceCoordinateJump(frame, retrace_jump_src, next_instr); \
 } while (0);
