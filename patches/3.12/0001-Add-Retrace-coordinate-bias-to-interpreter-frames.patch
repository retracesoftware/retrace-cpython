From e2db60eb1948758897449ac92832d38336bf8083 Mon Sep 17 00:00:00 2001
From: Retrace CPython Builder <retrace-cpython@retracesoftware.com>
Date: Thu, 7 May 2026 09:50:41 +0100
Subject: [PATCH 1/7] Add Retrace coordinate bias to interpreter frames

---
 Include/internal/pycore_frame.h |  6 ++++++
 Python/ceval.c                  |  8 ++++++++
 Python/ceval_macros.h           | 16 ++++++++++++++--
 3 files changed, 28 insertions(+), 2 deletions(-)

diff --git a/Include/internal/pycore_frame.h b/Include/internal/pycore_frame.h
index 4d355b2..203693b 100644
--- a/Include/internal/pycore_frame.h
+++ b/Include/internal/pycore_frame.h
@@ -6,6 +6,7 @@ extern "C" {

 #include <stdbool.h>
 #include <stddef.h>
+#include "cpython/retrace_state.h" // _PyRetraceFrameState
 #include "pycore_code.h"         // STATS

 /* See Objects/frame_layout.md for an explanation of the frame stack
@@ -70,6 +71,7 @@ typedef struct _PyInterpreterFrame {
      * If there is no callee, then it is meaningless. */
     uint16_t return_offset;
     char owner;
+    _PyRetraceFrameState retrace;
     /* Locals and stack */
     PyObject *localsplus[1];
 } _PyInterpreterFrame;
@@ -130,6 +132,10 @@ _PyFrame_Initialize(
     frame->prev_instr = _PyCode_CODE(code) - 1;
     frame->return_offset = 0;
     frame->owner = FRAME_OWNED_BY_THREAD;
+    frame->retrace.coordinate_bias = 0;
+    frame->retrace.coordinate_depth = _PyFrame_RETRACE_COORDINATE_DEPTH_UNSET;
+    frame->retrace.last_coordinate = _PyFrame_RETRACE_LAST_COORDINATE_UNSET;
+    frame->retrace.coordinate_hash = _PyFrame_RETRACE_COORDINATE_HASH_UNSET;

     for (int i = null_locals_from; i < code->co_nlocalsplus; i++) {
         frame->localsplus[i] = NULL;
diff --git a/Python/ceval.c b/Python/ceval.c
index 3985b52..3ed202c 100644
--- a/Python/ceval.c
+++ b/Python/ceval.c
@@ -701,9 +701,15 @@ _PyEval_EvalFrameDefault(PyThreadState *tstate, _PyInterpreterFrame *frame, int
     entry_frame.stacktop = 0;
     entry_frame.owner = FRAME_OWNED_BY_CSTACK;
     entry_frame.return_offset = 0;
+    entry_frame.retrace.coordinate_bias = 0;
+    entry_frame.retrace.coordinate_hash = _PyFrame_RETRACE_COORDINATE_HASH_UNSET;
+    _PyFrame_RetraceResetCoordinateDepth(&entry_frame);
+    _PyFrame_RetraceInitializeLastCoordinate(&entry_frame);
     /* Push frame */
     entry_frame.previous = prev_cframe->current_frame;
     frame->previous = &entry_frame;
+    _PyFrame_RetraceResetCoordinateDepth(frame);
+    _PyFrame_RetraceResetLastCoordinate(frame);
     cframe.current_frame = frame;

     tstate->c_recursion_remaining -= (PY_EVAL_C_STACK_UNITS - 1);
@@ -718,6 +723,7 @@ _PyEval_EvalFrameDefault(PyThreadState *tstate, _PyInterpreterFrame *frame, int
         if (_Py_EnterRecursivePy(tstate)) {
             goto exit_unwind;
         }
+        _PyRetrace_ActivateFrame(tstate, frame);
         /* Because this avoids the RESUME,
          * we need to update instrumentation */
         _Py_Instrument(frame->f_code, tstate->interp);
@@ -743,6 +749,7 @@ _PyEval_EvalFrameDefault(PyThreadState *tstate, _PyInterpreterFrame *frame, int
     if (_Py_EnterRecursivePy(tstate)) {
         goto exit_unwind;
     }
+    _PyRetrace_ActivateFrame(tstate, frame);

 resume_frame:
     SET_LOCALS_FROM_FRAME();
diff --git a/Python/ceval_macros.h b/Python/ceval_macros.h
index fccf908..7987816 100644
--- a/Python/ceval_macros.h
+++ b/Python/ceval_macros.h
@@ -144,8 +144,18 @@ GETITEM(PyObject *v, Py_ssize_t i) {
         opcode = word.op.code; \
         oparg = word.op.arg; \
     } while (0)
-#define JUMPTO(x)       (next_instr = _PyCode_CODE(frame->f_code) + (x))
-#define JUMPBY(x)       (next_instr += (x))
+#define JUMPTO(x) \
+    do { \
+        _Py_CODEUNIT *target = _PyCode_CODE(frame->f_code) + (x); \
+        _PyFrame_RetraceCoordinateJump(frame, frame->prev_instr, target); \
+        next_instr = target; \
+    } while (0)
+#define JUMPBY(x) \
+    do { \
+        _Py_CODEUNIT *target = next_instr + (x); \
+        _PyFrame_RetraceCoordinateJump(frame, frame->prev_instr, target); \
+        next_instr = target; \
+    } while (0)

 /* OpCode prediction macros
     Some opcodes tend to come in pairs thus making it possible to
@@ -334,6 +344,7 @@ do { \
 // for an exception handler, displaying the traceback, and so on
 #define INSTRUMENTED_JUMP(src, dest, event) \
 do { \
+    _Py_CODEUNIT *retrace_jump_src = (src); \
     _PyFrame_SetStackPointer(frame, stack_pointer); \
     next_instr = _Py_call_instrumentation_jump(tstate, event, frame, src, dest); \
     stack_pointer = _PyFrame_GetStackPointer(frame); \
@@ -341,4 +352,5 @@ do { \
         next_instr = (dest)+1; \
         goto error; \
     } \
+    _PyFrame_RetraceCoordinateJump(frame, retrace_jump_src, next_instr); \
 } while (0);
--
