From: nathan-retrace <nathan@retracesoftware.com>
Date: Tue, 5 May 2026 20:49:25 +0100
Subject: [PATCH] Update frame size tests for retrace field

---
 Lib/test/test_sys.py | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/Lib/test/test_sys.py b/Lib/test/test_sys.py
index 2f06299..5962572 100644
--- a/Lib/test/test_sys.py
+++ b/Lib/test/test_sys.py
@@ -1522,7 +1522,7 @@ class C(object): pass
         def func():
             return sys._getframe()
         x = func()
-        check(x, size('3Pi3c7P2ic??2P'))
+        check(x, size('3Pi3c7P2ic??q2P'))
         # function
         def func(): pass
         check(func, size('15Pi'))
@@ -1539,7 +1539,7 @@ def bar(cls):
             check(bar, size('PP'))
         # generator
         def get_gen(): yield 1
-        check(get_gen(), size('PP4P4c7P2ic??2P'))
+        check(get_gen(), size('PP4P4c7P2ic??q2P'))
         # iterator
         check(iter('abc'), size('lP'))
         # callable-iterator
-- 
