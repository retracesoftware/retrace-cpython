From df21e28618df720c24aaab29176b12c5c199c1fc Mon Sep 17 00:00:00 2001
From: Retrace CPython Builder <retrace-cpython@retracesoftware.com>
Date: Thu, 7 May 2026 09:50:42 +0100
Subject: [PATCH 4/7] Add retrace replay checkpoint callback

---
 Python/ceval.c        |  1 +
 Python/ceval_macros.h | 25 ++++++++++++++++++++++++-
 Python/pystate.c      |  7 +++++++
 3 files changed, 32 insertions(+), 1 deletion(-)

diff --git a/Python/ceval.c b/Python/ceval.c
index 3ed202c..97cfe6b 100644
--- a/Python/ceval.c
+++ b/Python/ceval.c
@@ -18,6 +18,7 @@
 #include "pycore_pymem.h"         // _PyMem_IsPtrFreed()
 #include "pycore_pystate.h"       // _PyInterpreterState_GET()
 #include "pycore_range.h"         // _PyRangeIterObject
+#include "pycore_retrace.h"       // _PyRetrace_CheckReplayCheckpoint()
 #include "pycore_sliceobject.h"   // _PyBuildSlice_ConsumeRefs
 #include "pycore_sysmodule.h"     // _PySys_Audit()
 #include "pycore_traceback.h"     // _PyTraceBack_FromFrame
diff --git a/Python/ceval_macros.h b/Python/ceval_macros.h
index 7987816..a67a697 100644
--- a/Python/ceval_macros.h
+++ b/Python/ceval_macros.h
@@ -59,6 +59,24 @@
     #define USE_COMPUTED_GOTOS 0
 #endif

+#define RETRACE_REPLAY_CHECKPOINT() \
+    do { \
+        PyInterpreterState *retrace_interp = tstate->interp; \
+        if (retrace_interp->retrace.replay_checkpoint_armed && \
+            retrace_interp->retrace.replay_checkpoint_thread_id == tstate->retrace.thread_id && \
+            _PyRetrace_FrameIsVisible(frame) && \
+            retrace_interp->retrace.replay_checkpoint_top == \
+                _PyRetrace_FrameCoordinate(frame)) \
+        { \
+            _PyFrame_SetStackPointer(frame, stack_pointer); \
+            int retrace_err = _PyRetrace_CheckReplayCheckpoint(tstate, frame); \
+            stack_pointer = _PyFrame_GetStackPointer(frame); \
+            if (retrace_err < 0) { \
+                goto error; \
+            } \
+        } \
+    } while (0)
+
 #ifdef Py_STATS
 #define INSTRUCTION_START(op) \
     do { \
@@ -66,9 +84,14 @@
         OPCODE_EXE_INC(op); \
         if (_py_stats) _py_stats->opcode_stats[lastopcode].pair_count[op]++; \
         lastopcode = op; \
+        RETRACE_REPLAY_CHECKPOINT(); \
     } while (0)
 #else
-#define INSTRUCTION_START(op) (frame->prev_instr = next_instr++)
+#define INSTRUCTION_START(op) \
+    do { \
+        frame->prev_instr = next_instr++; \
+        RETRACE_REPLAY_CHECKPOINT(); \
+    } while (0)
 #endif

 #if USE_COMPUTED_GOTOS
diff --git a/Python/pystate.c b/Python/pystate.c
index c8823e8..648b6c3 100644
--- a/Python/pystate.c
+++ b/Python/pystate.c
@@ -853,6 +853,11 @@ interpreter_clear(PyInterpreterState *interp, PyThreadState *tstate)
     Py_CLEAR(interp->audit_hooks);
     Py_CLEAR(interp->retrace.thread_yield_callback);
     Py_CLEAR(interp->retrace.thread_resume_callback);
+    _PyRetrace_ClearIdentityHashTable(interp);
+    interp->retrace.replay_checkpoint_armed = 0;
+    Py_CLEAR(interp->retrace.replay_checkpoint_coordinates);
+    Py_CLEAR(interp->retrace.replay_checkpoint_callback);
+    interp->retrace.replay_checkpoint_callback_active = 0;

     for (int i = 0; i < _PY_MONITORING_UNGROUPED_EVENTS; i++) {
         interp->monitors.tools[i] = 0;
--
