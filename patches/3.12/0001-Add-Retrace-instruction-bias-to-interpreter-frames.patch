From 06659c8a09d7e251b75d979652bdfe022df52fa9 Mon Sep 17 00:00:00 2001
From: nathan-retrace <nathan@retracesoftware.com>
Date: Tue, 5 May 2026 17:24:44 +0100
Subject: [PATCH 1/5] Add Retrace instruction bias to interpreter frames

---
 Include/internal/pycore_frame.h | 21 +++++++++++++++++++++
 Python/ceval.c                  |  1 +
 Python/ceval_macros.h           | 16 ++++++++++++++--
 3 files changed, 36 insertions(+), 2 deletions(-)

diff --git a/Include/internal/pycore_frame.h b/Include/internal/pycore_frame.h
index 4d355b2..fc97925 100644
--- a/Include/internal/pycore_frame.h
+++ b/Include/internal/pycore_frame.h
@@ -8,2 +8,3 @@ extern "C" {
 #include <stddef.h>
+#include <stdint.h>
 #include "pycore_code.h"         // STATS
@@ -72,2 +73,3 @@ typedef struct _PyInterpreterFrame {
     char owner;
+    int64_t retrace_instr_bias;
     /* Locals and stack */
@@ -79,2 +81,20 @@ typedef struct _PyInterpreterFrame {
 
+static inline int64_t
+_PyFrame_RetraceInstructionCoordinate(_PyInterpreterFrame *frame)
+{
+    return frame->retrace_instr_bias + (int64_t)_PyInterpreterFrame_LASTI(frame);
+}
+
+static inline void
+_PyFrame_RetraceInstructionJump(
+    _PyInterpreterFrame *frame,
+    _Py_CODEUNIT *from,
+    _Py_CODEUNIT *to)
+{
+    PyCodeObject *code = frame->f_code;
+    int from_offset = (int)(from - _PyCode_CODE(code));
+    int to_offset = (int)(to - _PyCode_CODE(code));
+    frame->retrace_instr_bias += (int64_t)from_offset + 1 - to_offset;
+}
+
 static inline PyObject **_PyFrame_Stackbase(_PyInterpreterFrame *f) {
@@ -132,2 +152,3 @@ _PyFrame_Initialize(
     frame->owner = FRAME_OWNED_BY_THREAD;
+    frame->retrace_instr_bias = 0;
 
diff --git a/Python/ceval.c b/Python/ceval.c
index 6110883..9385ba2 100644
--- a/Python/ceval.c
+++ b/Python/ceval.c
@@ -701,2 +701,3 @@ _PyEval_EvalFrameDefault(PyThreadState *tstate, _PyInterpreterFrame *frame, int
     entry_frame.return_offset = 0;
+    entry_frame.retrace_instr_bias = 0;
     /* Push frame */
diff --git a/Python/ceval_macros.h b/Python/ceval_macros.h
index fccf908..7b440d6 100644
--- a/Python/ceval_macros.h
+++ b/Python/ceval_macros.h
@@ -146,4 +146,14 @@ GETITEM(PyObject *v, Py_ssize_t i) {
     } while (0)
-#define JUMPTO(x)       (next_instr = _PyCode_CODE(frame->f_code) + (x))
-#define JUMPBY(x)       (next_instr += (x))
+#define JUMPTO(x) \
+    do { \
+        _Py_CODEUNIT *target = _PyCode_CODE(frame->f_code) + (x); \
+        _PyFrame_RetraceInstructionJump(frame, frame->prev_instr, target); \
+        next_instr = target; \
+    } while (0)
+#define JUMPBY(x) \
+    do { \
+        _Py_CODEUNIT *target = next_instr + (x); \
+        _PyFrame_RetraceInstructionJump(frame, frame->prev_instr, target); \
+        next_instr = target; \
+    } while (0)
 
@@ -336,2 +346,3 @@ do { \
 do { \
+    _Py_CODEUNIT *retrace_jump_src = (src); \
     _PyFrame_SetStackPointer(frame, stack_pointer); \
@@ -343,2 +354,3 @@ do { \
     } \
+    _PyFrame_RetraceInstructionJump(frame, retrace_jump_src, next_instr); \
 } while (0);
-- 
