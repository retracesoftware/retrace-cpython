From a4fd26348b80dce34b66fb124432aba355c45f13 Mon Sep 17 00:00:00 2001
From: Retrace CPython Builder <retrace-cpython@retracesoftware.com>
Date: Thu, 14 May 2026 14:10:01 +0100
Subject: [PATCH] Add Retrace coordinate-space lifecycle hooks

---
 Python/ceval.c             | 2 ++
 Python/ceval_macros.h      | 4 ++++
 Python/frame.c             | 1 +
 Python/generated_cases.c.h | 3 +++
 4 files changed, 10 insertions(+)

diff --git a/Python/ceval.c b/Python/ceval.c
index 3d4547a..6a72f22 100644
--- a/Python/ceval.c
+++ b/Python/ceval.c
@@ -934,6 +934,7 @@ _PyEval_EvalFrameDefault(PyThreadState *tstate, _PyInterpreterFrame *frame, int
 pop_1_error:
     STACK_SHRINK(1);
 error:
+        _PyRetrace_EndInstruction(tstate, frame);
         kwnames = NULL;
         /* Double-check exception status. */
 #ifdef NDEBUG
@@ -1584,6 +1585,7 @@ clear_gen_frame(PyThreadState *tstate, _PyInterpreterFrame * frame)
 static void
 _PyEvalFrameClearAndPop(PyThreadState *tstate, _PyInterpreterFrame * frame)
 {
+    _PyRetrace_LeaveFrame(tstate, frame);
     if (frame->owner == FRAME_OWNED_BY_THREAD) {
         clear_thread_frame(tstate, frame);
     }
diff --git a/Python/ceval_macros.h b/Python/ceval_macros.h
index e46c0a4..f0c0b20 100644
--- a/Python/ceval_macros.h
+++ b/Python/ceval_macros.h
@@ -83,12 +83,14 @@
         if (_py_stats) _py_stats->opcode_stats[lastopcode].pair_count[op]++; \
         lastopcode = op; \
         RETRACE_CALL_AT(); \
+        _PyRetrace_BeginInstruction(tstate, frame, op); \
     } while (0)
 #else
 #define INSTRUCTION_START(op) \
     do { \
         frame->prev_instr = next_instr++; \
         RETRACE_CALL_AT(); \
+        _PyRetrace_BeginInstruction(tstate, frame, op); \
     } while (0)
 #endif
 
@@ -112,6 +114,7 @@
 /* Do interpreter dispatch accounting for tracing and instrumentation */
 #define DISPATCH() \
     { \
+        _PyRetrace_EndInstruction(tstate, frame); \
         NEXTOPARG(); \
         PRE_DISPATCH_GOTO(); \
         DISPATCH_GOTO(); \
@@ -119,6 +122,7 @@
 
 #define DISPATCH_SAME_OPARG() \
     { \
+        _PyRetrace_EndInstruction(tstate, frame); \
         opcode = next_instr->op.code; \
         PRE_DISPATCH_GOTO(); \
         DISPATCH_GOTO(); \
diff --git a/Python/frame.c b/Python/frame.c
index b84fd9b..345ee7f 100644
--- a/Python/frame.c
+++ b/Python/frame.c
@@ -68,6 +68,7 @@ _PyFrame_Copy(_PyInterpreterFrame *src, _PyInterpreterFrame *dest)
     assert(src->stacktop >= src->f_code->co_nlocalsplus);
     Py_ssize_t size = ((char*)&src->localsplus[src->stacktop]) - (char *)src;
     memcpy(dest, src, size);
+    _PyRetraceFrameState_Init(&dest->retrace);
     // Don't leave a dangling pointer to the old frame when creating generators
     // and coroutines:
     dest->previous = NULL;
diff --git a/Python/generated_cases.c.h b/Python/generated_cases.c.h
index 246d37e..4a9f8ff 100644
--- a/Python/generated_cases.c.h
+++ b/Python/generated_cases.c.h
@@ -1237,6 +1237,7 @@
             gen->gi_exc_state.previous_item = NULL;
             _Py_LeaveRecursiveCallPy(tstate);
             _PyInterpreterFrame *gen_frame = frame;
+            _PyRetrace_SuspendFrame(tstate, gen_frame);
             frame = cframe.current_frame = frame->previous;
             gen_frame->previous = NULL;
             _PyFrame_StackPush(frame, retval);
@@ -1258,6 +1259,7 @@
             gen->gi_exc_state.previous_item = NULL;
             _Py_LeaveRecursiveCallPy(tstate);
             _PyInterpreterFrame *gen_frame = frame;
+            _PyRetrace_SuspendFrame(tstate, gen_frame);
             frame = cframe.current_frame = frame->previous;
             gen_frame->previous = NULL;
             _PyFrame_StackPush(frame, retval);
@@ -4563,6 +4565,7 @@
             _Py_LeaveRecursiveCallPy(tstate);
             assert(frame != &entry_frame);
             _PyInterpreterFrame *prev = frame->previous;
+            _PyRetrace_LeaveFrame(tstate, frame);
             _PyThreadState_PopFrame(tstate, frame);
             frame = cframe.current_frame = prev;
             _PyFrame_StackPush(frame, (PyObject *)gen);
-- 
