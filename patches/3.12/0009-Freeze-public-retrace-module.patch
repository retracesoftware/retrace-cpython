From 744d18e5b231af3a80bf421f7c3953ed8b165bb0 Mon Sep 17 00:00:00 2001
From: Retrace CPython Builder <retrace-cpython@retracesoftware.com>
Date: Mon, 11 May 2026 00:00:00 +0100
Subject: [PATCH] Freeze public retrace module

---
 Makefile.pre.in                        | 6 ++++++
 PCbuild/_freeze_module.vcxproj         | 6 ++++++
 PCbuild/_freeze_module.vcxproj.filters | 3 +++
 Python/frozen.c                        | 5 +++++
 Tools/build/freeze_modules.py          | 3 +++
 5 files changed, 23 insertions(+)

diff --git a/Makefile.pre.in b/Makefile.pre.in
index 7ca3dc6..4f95b62 100644
--- a/Makefile.pre.in
+++ b/Makefile.pre.in
@@ -1124,2 +1124,3 @@ FROZEN_FILES_IN = \
 		Lib/runpy.py \
+		Lib/retrace.py \
 		Lib/__hello__.py \
@@ -1149,2 +1150,3 @@ FROZEN_FILES_OUT = \
 		Python/frozen_modules/runpy.h \
+		Python/frozen_modules/retrace.h \
 		Python/frozen_modules/__hello__.h \
@@ -1221,2 +1223,5 @@ Python/frozen_modules/runpy.h: Lib/runpy.py $(FREEZE_MODULE_DEPS)
 
+Python/frozen_modules/retrace.h: Lib/retrace.py $(FREEZE_MODULE_DEPS)
+	$(FREEZE_MODULE) retrace $(srcdir)/Lib/retrace.py Python/frozen_modules/retrace.h
+
 Python/frozen_modules/__hello__.h: Lib/__hello__.py $(FREEZE_MODULE_DEPS)
@@ -1276,2 +1281,3 @@ $(DEEPFREEZE_C): $(DEEPFREEZE_DEPS)
 	Python/frozen_modules/runpy.h:runpy \
+	Python/frozen_modules/retrace.h:retrace \
 	Python/frozen_modules/__hello__.h:__hello__ \
diff --git a/PCbuild/_freeze_module.vcxproj b/PCbuild/_freeze_module.vcxproj
index 0266395..090a6b1 100644
--- a/PCbuild/_freeze_module.vcxproj
+++ b/PCbuild/_freeze_module.vcxproj
@@ -334,2 +334,7 @@
     </None>
+    <None Include="..\Lib\retrace.py">
+      <ModName>retrace</ModName>
+      <IntFile>$(IntDir)retrace.g.h</IntFile>
+      <OutFile>$(PySourcePath)Python\frozen_modules\retrace.h</OutFile>
+    </None>
     <None Include="..\Lib\__hello__.py">
@@ -424,2 +429,3 @@
 		 "$(PySourcePath)Python\frozen_modules\runpy.h:runpy" ^
+		 "$(PySourcePath)Python\frozen_modules\retrace.h:retrace" ^
 		 "$(PySourcePath)Python\frozen_modules\__hello__.h:__hello__" ^
diff --git a/PCbuild/_freeze_module.vcxproj.filters b/PCbuild/_freeze_module.vcxproj.filters
index d98a4c5..3fcc346 100644
--- a/PCbuild/_freeze_module.vcxproj.filters
+++ b/PCbuild/_freeze_module.vcxproj.filters
@@ -482,2 +482,5 @@
     </None>
+    <None Include="..\Lib\retrace.py">
+      <Filter>Python Files</Filter>
+    </None>
     <None Include="..\Lib\__hello__.py">
diff --git a/Python/frozen.c b/Python/frozen.c
index f8e0b8b..bacffe2 100644
--- a/Python/frozen.c
+++ b/Python/frozen.c
@@ -60,2 +60,3 @@
 #include "frozen_modules/runpy.h"
+#include "frozen_modules/retrace.h"
 #include "frozen_modules/__hello__.h"
@@ -88,2 +89,3 @@ extern PyObject *_Py_get_importlib_machinery_toplevel(void);
 extern PyObject *_Py_get_runpy_toplevel(void);
+extern PyObject *_Py_get_retrace_toplevel(void);
 extern PyObject *_Py_get___hello___toplevel(void);
@@ -123,2 +125,5 @@ static const struct _frozen stdlib_modules[] = {
     {"runpy", _Py_M__runpy, (int)sizeof(_Py_M__runpy), false, GET_CODE(runpy)},
+
+    /* retrace */
+    {"retrace", _Py_M__retrace, (int)sizeof(_Py_M__retrace), false, GET_CODE(retrace)},
     {0, 0, 0} /* stdlib sentinel */
diff --git a/Tools/build/freeze_modules.py b/Tools/build/freeze_modules.py
index 5e3bd1f..2252117 100644
--- a/Tools/build/freeze_modules.py
+++ b/Tools/build/freeze_modules.py
@@ -78,2 +78,5 @@
     ]),
+    ('retrace', [
+        'retrace',
+    ]),
     (TESTS_SECTION, [
-- 
2.50.1 (Apple Git-155)
