--- a/Python/pystate.c
+++ b/Python/pystate.c
@@ -851,6 +851,10 @@ interpreter_clear(PyInterpreterState *interp, PyThreadState *tstate)
     // XXX Make sure we properly deal with problematic finalizers.
 
