From 534b9d59c3b34c3bc4793ba208db3bba461ec6aa Mon Sep 17 00:00:00 2001
From: Retrace CPython Builder <retrace-cpython@retracesoftware.com>
Date: Thu, 7 May 2026 09:50:59 +0100
Subject: [PATCH 1/6] Add Retrace coordinate bias to interpreter frames

---
 Include/internal/pycore_frame.h |  6 ++++++
 Python/ceval.c                  | 20 ++++++++++++++++++--
 2 files changed, 24 insertions(+), 2 deletions(-)

diff --git a/Include/internal/pycore_frame.h b/Include/internal/pycore_frame.h
index 4866ea2..1e40ec5 100644
--- a/Include/internal/pycore_frame.h
+++ b/Include/internal/pycore_frame.h
@@ -6,6 +6,7 @@ extern "C" {

 #include <stdbool.h>
 #include <stddef.h>
+#include "cpython/retrace_state.h" // _PyRetraceFrameState

 /* See Objects/frame_layout.md for an explanation of the frame stack
  * including explanation of the PyFrameObject and _PyInterpreterFrame
@@ -62,6 +63,7 @@ typedef struct _PyInterpreterFrame {
     int stacktop;     /* Offset of TOS from localsplus  */
     bool is_entry;  // Whether this is the "root" frame for the current _PyCFrame.
     char owner;
+    _PyRetraceFrameState retrace;
     /* Locals and stack */
     PyObject *localsplus[1];
 } _PyInterpreterFrame;
@@ -113,6 +115,7 @@ _PyFrame_InitializeSpecials(
     frame->prev_instr = _PyCode_CODE(frame->f_code) - 1;
     frame->is_entry = false;
     frame->owner = FRAME_OWNED_BY_THREAD;
+    _PyRetraceFrameState_Init(&frame->retrace);
 }

 /* Gets the pointer to the locals array
diff --git a/Python/ceval.c b/Python/ceval.c
index 1ce6bbc..f1d1fed 100644
--- a/Python/ceval.c
+++ b/Python/ceval.c
@@ -1364,8 +1364,18 @@ eval_frame_handle_pending(PyThreadState *tstate)
         opcode = _Py_OPCODE(word); \
         oparg = _Py_OPARG(word); \
     } while (0)
-#define JUMPTO(x)       (next_instr = first_instr + (x))
-#define JUMPBY(x)       (next_instr += (x))
+#define JUMPTO(x) \
+    do { \
+        _Py_CODEUNIT *target = first_instr + (x); \
+        _PyFrame_RetraceCoordinateJump(frame, frame->prev_instr, target); \
+        next_instr = target; \
+    } while (0)
+#define JUMPBY(x) \
+    do { \
+        _Py_CODEUNIT *target = next_instr + (x); \
+        _PyFrame_RetraceCoordinateJump(frame, frame->prev_instr, target); \
+        next_instr = target; \
+    } while (0)

 // Skip from a PRECALL over a CALL to the next instruction:
 #define SKIP_CALL() \
@@ -1664,6 +1674,7 @@ _PyEval_EvalFrameDefault(PyThreadState *tstate, _PyInterpreterFrame *frame, int
     frame->is_entry = true;
     /* Push frame */
     frame->previous = prev_cframe->current_frame;
+    _PyFrame_RetraceResetLastCoordinate(frame);
     cframe.current_frame = frame;

     /* support for generator.throw() */
@@ -1672,6 +1683,7 @@ _PyEval_EvalFrameDefault(PyThreadState *tstate, _PyInterpreterFrame *frame, int
             tstate->recursion_remaining--;
             goto exit_unwind;
         }
+        _PyRetrace_ActivateFrame(tstate, frame);
         TRACE_FUNCTION_THROW_ENTRY();
         DTRACE_FUNCTION_ENTRY();
         goto resume_with_error;
@@ -1712,6 +1724,7 @@ _PyEval_EvalFrameDefault(PyThreadState *tstate, _PyInterpreterFrame *frame, int
         tstate->recursion_remaining--;
         goto exit_unwind;
     }
+    _PyRetrace_ActivateFrame(tstate, frame);

 resume_frame:
     SET_LOCALS_FROM_FRAME();
@@ -5642,6 +5655,7 @@ _PyEval_EvalFrameDefault(PyThreadState *tstate, _PyInterpreterFrame *frame, int
                     int err;
                     /* see maybe_call_line_trace()
                     for expository comments */
+                    _Py_CODEUNIT *retrace_jump_src = next_instr;
                     _PyFrame_SetStackPointer(frame, stack_pointer);

                     err = maybe_call_line_trace(tstate->c_tracefunc,
@@ -5666,6 +5680,8 @@ _PyEval_EvalFrameDefault(PyThreadState *tstate, _PyInterpreterFrame *frame, int
                     // Reload next_instr. Don't increment it, though, since
                     // we're going to re-dispatch to the "true" instruction now:
                     next_instr = frame->prev_instr;
+                    _PyFrame_RetraceCoordinateJump(
+                        frame, retrace_jump_src, next_instr);
                 }
             }
         }
--
