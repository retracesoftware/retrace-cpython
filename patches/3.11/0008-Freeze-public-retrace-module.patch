@@ -104,6 +105,9 @@ static const struct _frozen stdlib_modules[] = {
     {"importlib.util", NULL, 0, false, GET_CODE(importlib_util)},
     {"importlib.machinery", NULL, 0, false, GET_CODE(importlib_machinery)},
