From 7e8f47af738ffa74d8e818ba12e5626ac4680e01 Mon Sep 17 00:00:00 2001
From: nathan-retrace <nathan@retracesoftware.com>
Date: Tue, 5 May 2026 21:56:19 +0100
Subject: [PATCH 3/5] Add retrace thread switch callback

---
 Include/cpython/pystate.h         |   4 +
 Include/internal/pycore_interp.h  |   5 +
 Python/ceval.c                    |   5 +
 Python/ceval_gil.h                |   5 +-
 Python/pystate.c                  |   4 +

diff --git a/Include/cpython/pystate.h b/Include/cpython/pystate.h
index 2bd4606..a2acadc 100644
--- a/Include/cpython/pystate.h
+++ b/Include/cpython/pystate.h
@@ -202,2 +202,6 @@ struct _ts {
     _PyCFrame root_cframe;
+
+    int retrace_thread_switch_pending;
+    unsigned long retrace_thread_switch_from_id;
+    struct _PyInterpreterFrame *retrace_thread_switch_frame;
 };
diff --git a/Include/internal/pycore_interp.h b/Include/internal/pycore_interp.h
index 02d25d6..98614d0 100644
--- a/Include/internal/pycore_interp.h
+++ b/Include/internal/pycore_interp.h
@@ -180,2 +180,7 @@ struct _is {
 
+    PyObject *retrace_thread_switch_callback;
+    int retrace_thread_switch_callback_active;
+    PyThreadState *retrace_thread_switch_callback_tstate;
+    struct _PyInterpreterFrame *retrace_thread_switch_callback_frame;
+
     /* The following fields are here to avoid allocation during init.
diff --git a/Python/ceval.c b/Python/ceval.c
index 4ded04c..c7f7e7e 100644
--- a/Python/ceval.c
+++ b/Python/ceval.c
@@ -22,2 +22,3 @@
 #include "pycore_pystate.h"       // _PyInterpreterState_GET()
+#include "pycore_retrace.h"       // _PyRetrace_NoteThreadSwitch()
 #include "pycore_sysmodule.h"     // _PySys_Audit()
@@ -413,2 +414,3 @@ PyEval_AcquireLock(void)
     take_gil(tstate);
+    _PyRetrace_DeliverThreadSwitchCallback(tstate);
 }
@@ -447,2 +449,3 @@ PyEval_AcquireThread(PyThreadState *tstate)
     }
+    _PyRetrace_DeliverThreadSwitchCallback(tstate);
 }
@@ -524,2 +527,3 @@ PyEval_RestoreThread(PyThreadState *tstate)
     _PyThreadState_Swap(gilstate, tstate);
+    _PyRetrace_DeliverThreadSwitchCallback(tstate);
 }
@@ -1209,2 +1213,3 @@ eval_frame_handle_pending(PyThreadState *tstate)
         }
+        _PyRetrace_DeliverThreadSwitchCallback(tstate);
     }
diff --git a/Python/ceval_gil.h b/Python/ceval_gil.h
index 94e2df0..0eecef6 100644
--- a/Python/ceval_gil.h
+++ b/Python/ceval_gil.h
@@ -268,5 +268,8 @@ take_gil(PyThreadState *tstate)
 
-    if (tstate != (PyThreadState*)_Py_atomic_load_relaxed(&gil->last_holder)) {
+    PyThreadState *previous_holder =
+        (PyThreadState*)_Py_atomic_load_relaxed(&gil->last_holder);
+    if (tstate != previous_holder) {
         _Py_atomic_store_relaxed(&gil->last_holder, (uintptr_t)tstate);
         ++gil->switch_number;
+        _PyRetrace_NoteThreadSwitch(previous_holder, tstate);
     }
diff --git a/Python/pystate.c b/Python/pystate.c
index a451166..f3bf9fc 100644
--- a/Python/pystate.c
+++ b/Python/pystate.c
@@ -413,2 +413,6 @@ interpreter_clear(PyInterpreterState *interp, PyThreadState *tstate)
     Py_CLEAR(interp->audit_hooks);
+    Py_CLEAR(interp->retrace_thread_switch_callback);
+    interp->retrace_thread_switch_callback_active = 0;
+    interp->retrace_thread_switch_callback_tstate = NULL;
+    interp->retrace_thread_switch_callback_frame = NULL;
 
-- 
2.50.1 (Apple Git-155)

