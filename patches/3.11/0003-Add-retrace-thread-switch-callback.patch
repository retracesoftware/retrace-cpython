diff --git a/Include/internal/pycore_retrace.h b/Include/internal/pycore_retrace.h
new file mode 100644
index 0000000..0dff810
--- /dev/null
+++ b/Include/internal/pycore_retrace.h
@@ -0,0 +1,19 @@
+#ifndef Py_INTERNAL_RETRACE_H
+#define Py_INTERNAL_RETRACE_H
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+#ifndef Py_BUILD_CORE
+#  error "this header requires Py_BUILD_CORE define"
+#endif
+
+PyAPI_FUNC(void) _PyRetrace_NoteThreadSwitch(
+    PyThreadState *from_tstate,
+    PyThreadState *to_tstate);
+PyAPI_FUNC(void) _PyRetrace_DeliverThreadSwitchCallback(PyThreadState *tstate);
+
+#ifdef __cplusplus
+}
+#endif
+#endif /* !Py_INTERNAL_RETRACE_H */
diff --git a/Modules/retracemodule.c b/Modules/retracemodule.c
