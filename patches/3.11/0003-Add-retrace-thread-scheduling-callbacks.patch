From 4905b98640c53c71636431a023e150fb6d0df228 Mon Sep 17 00:00:00 2001
From: Retrace CPython Builder <retrace-cpython@retracesoftware.com>
Date: Thu, 7 May 2026 09:50:59 +0100
Subject: [PATCH 3/6] Add retrace thread scheduling callbacks

---
 Include/cpython/pystate.h        | 4 ++++
 Include/internal/pycore_interp.h | 3 +++
 Modules/_threadmodule.c          | 19 +++++++++++++++----
 Modules/signalmodule.c           |  3 +++
 Python/ceval.c                   | 6 ++++++
 Python/ceval_gil.h               | 5 ++++-
 Python/pystate.c                 | 13 ++++++++++---
 7 files changed, 51 insertions(+), 9 deletions(-)

diff --git a/Include/cpython/pystate.h b/Include/cpython/pystate.h
index 2bd4606..27f32ad 100644
--- a/Include/cpython/pystate.h
+++ b/Include/cpython/pystate.h
@@ -2,6 +2,8 @@
 #  error "this header file must not be included directly"
 #endif

+#include "cpython/retrace_state.h" // _PyRetraceThreadState
+

 PyAPI_FUNC(int) _PyInterpreterState_RequiresIDRef(PyInterpreterState *);
 PyAPI_FUNC(void) _PyInterpreterState_RequireIDRef(PyInterpreterState *, int);
@@ -200,6 +202,8 @@ struct _ts {

     /* The bottom-most frame on the stack. */
     _PyCFrame root_cframe;
+
+    _PyRetraceThreadState retrace;
 };


diff --git a/Include/internal/pycore_interp.h b/Include/internal/pycore_interp.h
index 02d25d6..ce4b15f 100644
--- a/Include/internal/pycore_interp.h
+++ b/Include/internal/pycore_interp.h
@@ -25,6 +25,7 @@ extern "C" {
 #include "pycore_typeobject.h"    // struct type_cache
 #include "pycore_unicodeobject.h" // struct _Py_unicode_state
 #include "pycore_warnings.h"      // struct _warnings_runtime_state
+#include "cpython/retrace_state.h" // _PyRetraceInterpreterState

 struct _pending_calls {
     PyThread_type_lock lock;
@@ -178,6 +179,8 @@ struct _is {

     int int_max_str_digits;

+    _PyRetraceInterpreterState retrace;
+
     /* The following fields are here to avoid allocation during init.
        The data is exposed through PyInterpreterState pointer fields.
        These fields should not be accessed directly outside of init.
diff --git a/Modules/_threadmodule.c b/Modules/_threadmodule.c
index 70c27c0..9d59d81 100644
--- a/Modules/_threadmodule.c
+++ b/Modules/_threadmodule.c
@@ -6,4 +6,5 @@
 #include "pycore_moduleobject.h"  // _PyModule_GetState()
 #include "pycore_pylifecycle.h"
 #include "pycore_pystate.h"       // _PyThreadState_SetCurrent()
+#include "pycore_retrace.h"       // retrace thread helpers
 #include <stddef.h>               // offsetof()
@@ -1201,5 +1202,6 @@ thread_PyThread_start_new_thread(PyObject *self, PyObject *fargs)
         thread_bootstate_free(boot, 1);
         return NULL;
     }
+    _PyRetrace_RegisterThreadIdent(boot->tstate, ident);
-    return PyLong_FromUnsignedLong(ident);
+    return _PyRetrace_ThreadIdentObject(boot->tstate);
 }
@@ -1276,8 +1278,3 @@ thread_get_ident(PyObject *self, PyObject *Py_UNUSED(ignored))
 {
-    unsigned long ident = PyThread_get_thread_ident();
-    if (ident == PYTHREAD_INVALID_THREAD_ID) {
-        PyErr_SetString(ThreadError, "no current thread ident");
-        return NULL;
-    }
-    return PyLong_FromUnsignedLong(ident);
+    return _PyRetrace_ThreadIdentObject(_PyThreadState_GET());
 }
@@ -1461,19 +1458,21 @@ thread_excepthook_file(PyObject *file, PyObject *exc_type, PyObject *exc_value,
         Py_DECREF(name);
     }
     else {
-        unsigned long ident = PyThread_get_thread_ident();
-        PyObject *str = PyUnicode_FromFormat("%lu", ident);
+        PyObject *ident = _PyRetrace_ThreadIdentObject(_PyThreadState_GET());
+        if (ident == NULL) {
+            PyErr_Clear();
+        }
+        PyObject *str = ident == NULL ? NULL : PyObject_Str(ident);
+        Py_XDECREF(ident);
         if (str != NULL) {
             if (PyFile_WriteObject(str, file, Py_PRINT_RAW) < 0) {
                 Py_DECREF(str);
                 return -1;
             }
             Py_DECREF(str);
         }
         else {
-            PyErr_Clear();
-
             if (PyFile_WriteString("<failed to get thread name>", file) < 0) {
                 return -1;
             }
         }
     }
diff --git a/Modules/signalmodule.c b/Modules/signalmodule.c
index c6c297a..2de6c0f 100644
--- a/Modules/signalmodule.c
+++ b/Modules/signalmodule.c
@@ -13,4 +13,5 @@
 #include "pycore_moduleobject.h"  // _PyModule_GetState()
 #include "pycore_pyerrors.h"      // _PyErr_SetString()
 #include "pycore_pystate.h"       // _PyThreadState_GET()
+#include "pycore_retrace.h"       // retrace thread helpers
 #include "pycore_signal.h"        // Py_NSIG
@@ -1328,6 +1329,8 @@ signal_pthread_kill_impl(PyObject *module, unsigned long thread_id,
         return NULL;
     }
-
+
+    thread_id = _PyRetrace_CPythonThreadIdentFromPublicIdent(
+        _PyInterpreterState_GET(), thread_id);
     err = pthread_kill((pthread_t)thread_id, signalnum);
     if (err != 0) {
         errno = err;
diff --git a/Python/ceval.c b/Python/ceval.c
index f1d1fed..3816a42 100644
--- a/Python/ceval.c
+++ b/Python/ceval.c
@@ -20,6 +20,7 @@
 #include "pycore_pylifecycle.h"   // _PyErr_Print()
 #include "pycore_pymem.h"         // _PyMem_IsPtrFreed()
 #include "pycore_pystate.h"       // _PyInterpreterState_GET()
+#include "pycore_retrace.h"       // thread scheduling callbacks
 #include "pycore_sysmodule.h"     // _PySys_Audit()
 #include "pycore_tuple.h"         // _PyTuple_ITEMS()
 #include "pycore_emscripten_signal.h"  // _Py_CHECK_EMSCRIPTEN_SIGNALS
@@ -411,6 +412,7 @@ PyEval_AcquireLock(void)
     _Py_EnsureTstateNotNULL(tstate);

     take_gil(tstate);
+    _PyRetrace_DeliverThreadResumeCallback(tstate);
 }

 void
@@ -445,6 +447,7 @@ PyEval_AcquireThread(PyThreadState *tstate)
     if (_PyThreadState_Swap(gilstate, tstate) != NULL) {
         Py_FatalError("non-NULL old thread state");
     }
+    _PyRetrace_DeliverThreadResumeCallback(tstate);
 }

 void
@@ -522,6 +525,7 @@ PyEval_RestoreThread(PyThreadState *tstate)

     struct _gilstate_runtime_state *gilstate = &tstate->interp->runtime->gilstate;
     _PyThreadState_Swap(gilstate, tstate);
+    _PyRetrace_DeliverThreadResumeCallback(tstate);
 }


@@ -1195,6 +1199,7 @@ eval_frame_handle_pending(PyThreadState *tstate)
     /* GIL drop request */
     if (_Py_atomic_load_relaxed_int32(&ceval2->gil_drop_request)) {
         /* Give another thread a chance */
+        _PyRetrace_DeliverThreadYieldCallback(tstate);
         if (_PyThreadState_Swap(&runtime->gilstate, NULL) != tstate) {
             Py_FatalError("tstate mix-up");
         }
@@ -1207,6 +1212,7 @@ eval_frame_handle_pending(PyThreadState *tstate)
         if (_PyThreadState_Swap(&runtime->gilstate, tstate) != NULL) {
             Py_FatalError("orphan tstate");
         }
+        _PyRetrace_DeliverThreadResumeCallback(tstate);
     }

     /* Check for asynchronous exception. */
diff --git a/Python/ceval_gil.h b/Python/ceval_gil.h
index 94e2df0..bc5ddb1 100644
--- a/Python/ceval_gil.h
+++ b/Python/ceval_gil.h
@@ -266,9 +266,12 @@ take_gil(PyThreadState *tstate)
     _Py_atomic_store_relaxed(&gil->locked, 1);
     _Py_ANNOTATE_RWLOCK_ACQUIRED(&gil->locked, /*is_write=*/1);

-    if (tstate != (PyThreadState*)_Py_atomic_load_relaxed(&gil->last_holder)) {
+    PyThreadState *previous_holder =
+        (PyThreadState*)_Py_atomic_load_relaxed(&gil->last_holder);
+    if (tstate != previous_holder) {
         _Py_atomic_store_relaxed(&gil->last_holder, (uintptr_t)tstate);
         ++gil->switch_number;
+        _PyRetrace_NoteThreadResume(tstate);
     }

 #ifdef FORCE_SWITCHING
diff --git a/Python/pystate.c b/Python/pystate.c
index a451166..1c93702 100644
--- a/Python/pystate.c
+++ b/Python/pystate.c
@@ -7,7 +7,8 @@
 #include "pycore_object.h"        // _PyType_InitCache()
 #include "pycore_pyerrors.h"
 #include "pycore_pylifecycle.h"
 #include "pycore_pymem.h"         // _PyMem_SetDefaultAllocator()
+#include "pycore_retrace.h"       // thread-state helpers
 #include "pycore_pystate.h"       // _PyThreadState_GET()
 #include "pycore_runtime_init.h"  // _PyRuntimeState_INIT
 #include "pycore_sysmodule.h"
@@ -411,6 +411,8 @@ interpreter_clear(PyInterpreterState *interp, PyThreadState *tstate)
     }

     Py_CLEAR(interp->audit_hooks);
+    Py_CLEAR(interp->retrace.thread_yield_callback);
+    Py_CLEAR(interp->retrace.thread_resume_callback);

     PyConfig_Clear(&interp->config);
     Py_CLEAR(interp->codec_search_path);
@@ -796,6 +798,7 @@ init_threadstate(PyThreadState *tstate,

     tstate->cframe = &tstate->root_cframe;
     tstate->datastack_chunk = NULL;
+    _PyRetrace_InitializeThreadState(interp, tstate);
     tstate->datastack_top = NULL;
     tstate->datastack_limit = NULL;

@@ -1071,5 +1074,6 @@ PyThreadState_Clear(PyThreadState *tstate)
     Py_CLEAR(tstate->context);
-
+    _PyRetrace_ClearThreadState(tstate);
+
     if (tstate->on_delete != NULL) {
         tstate->on_delete(tstate->on_delete_data);
     }
@@ -856,6 +861,8 @@ new_threadstate(PyInterpreterState *interp)
     interp->threads.head = tstate;

     init_threadstate(tstate, interp, id, old_head);
+    _PyRetrace_SeedThreadState(
+        _PyRuntimeGILState_GetThreadState(&runtime->gilstate), tstate);

     HEAD_UNLOCK(runtime);
     if (!used_newtstate) {
@@ -1328,6 +1335,6 @@ PyThreadState_SetAsyncExc(unsigned long id, PyObject *exc)
      */
     HEAD_LOCK(runtime);
     for (PyThreadState *tstate = interp->threads.head; tstate != NULL; tstate = tstate->next) {
-        if (tstate->thread_id != id) {
+        if (!_PyRetrace_ThreadMatchesAsyncExcId(interp, tstate, id)) {
             continue;
         }
@@ -1432,7 +1439,7 @@ _PyThread_CurrentFrames(void)
             if (frame == NULL) {
                 continue;
             }
-            PyObject *id = PyLong_FromUnsignedLong(t->thread_id);
+            PyObject *id = _PyRetrace_ThreadIdentObject(t);
             if (id == NULL) {
                 goto fail;
             }
@@ -1499,7 +1506,7 @@ _PyThread_CurrentExceptions(void)
             if (err_info == NULL) {
                 continue;
             }
-            PyObject *id = PyLong_FromUnsignedLong(t->thread_id);
+            PyObject *id = _PyRetrace_ThreadIdentObject(t);
             if (id == NULL) {
                 goto fail;
             }
--
2.50.1 (Apple Git-155)
